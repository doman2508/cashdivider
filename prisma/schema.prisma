generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  rules          AllocationRule[]
  imports        Import[]
  transactions   BankTransaction[]
  dailySummaries DailySummary[]
  paymentBatches PaymentBatch[]
  subaccountBalanceAdjustments SubaccountBalanceAdjustment[]
}

model AllocationRule {
  id                  String   @id @default(cuid())
  userId              String
  name                String
  percentage          Decimal  @db.Decimal(5, 2)
  targetLabel         String
  targetAccountNumber String
  position            Int      @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  batchItems          PaymentBatchItem[]

  @@index([userId, position])
}

model Import {
  id           String            @id @default(cuid())
  userId       String
  sourceType   ImportSourceType
  sourceName   String
  fingerprint  String
  importedAt   DateTime          @default(now())
  addedCount   Int
  skippedCount Int
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]

  @@unique([userId, fingerprint])
  @@index([userId, importedAt])
}

model BankTransaction {
  id           String   @id @default(cuid())
  userId       String
  importId     String?
  bookingDate  DateTime
  amount       Decimal  @db.Decimal(12, 2)
  description  String
  counterparty String?
  transactionKey String
  isExcluded   Boolean  @default(false)
  excludedAt   DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  import       Import?  @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@unique([userId, transactionKey])
  @@index([userId, bookingDate])
}

model DailySummary {
  id           String            @id @default(cuid())
  userId       String
  date         DateTime
  totalIncome  Decimal           @db.Decimal(12, 2)
  status       DailySummaryStatus @default(OPEN)
  includeInBatch Boolean         @default(true)
  settledAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentBatch PaymentBatch?

  @@unique([userId, date])
  @@index([userId, status])
}

model PaymentBatch {
  id            String             @id @default(cuid())
  userId        String
  dailySummaryId String            @unique
  status        PaymentBatchStatus @default(GENERATED)
  totalAmount   Decimal            @db.Decimal(12, 2)
  leftoverAmount Decimal           @db.Decimal(12, 2)
  createdAt     DateTime           @default(now())
  completedAt   DateTime?
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailySummary  DailySummary       @relation(fields: [dailySummaryId], references: [id], onDelete: Cascade)
  items         PaymentBatchItem[]

  @@index([userId, status])
}

model PaymentBatchItem {
  id                  String       @id @default(cuid())
  batchId             String
  ruleId              String?
  categoryName        String
  targetLabel         String
  targetAccountNumber String
  amount              Decimal      @db.Decimal(12, 2)
  paymentType         String
  batch               PaymentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rule                AllocationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([batchId])
}

model SubaccountBalanceAdjustment {
  id                  String   @id @default(cuid())
  userId              String
  accountKey          String
  categoryName        String
  targetLabel         String
  targetAccountNumber String
  deltaAmount         Decimal  @db.Decimal(12, 2)
  resultingBalance    Decimal  @db.Decimal(12, 2)
  note                String?
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, accountKey, createdAt])
}

enum ImportSourceType {
  ING_CSV
  MANUAL
}

enum DailySummaryStatus {
  OPEN
  SETTLED
}

enum PaymentBatchStatus {
  GENERATED
  COMPLETED
}
